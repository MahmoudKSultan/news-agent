# Email (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# LLM (optional - Ollama runs locally by default)
# GEMINI_API_KEY=your_gemini_key_here

# Translation (optional - LibreTranslate self-hosted or argos-translate offline)
# LIBRETRANSLATE_URL=http://localhost:5000

# Database (optional - defaults to SQLite)
# DATABASE_URL=file:./data/news-agent.db
